{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Git: Push to GitHub",
      "type": "shell",
      "command": "git",
      "args": ["push"],
      "problemMatcher": []
    },
    {
      "label": "Serve: Reveal Jeopardy",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "uvicorn",
        "server:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "${input:serverPort}"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "uvicorn",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Will watch for changes",
          "endsPattern": "Application startup complete"
        }
      }
    },
    {
      "label": "Serve: Stop Reveal Jeopardy Servers",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "pkill -f 'uvicorn server:app' || true"
      ],
      "problemMatcher": []
    },
    {
      "label": "GitHub: Create release",
      "type": "shell",
      "command": "gh",
      "args": [
        "release",
        "create",
        "${input:releaseTag}",
        "--target",
        "master",
        "--generate-notes",
        "--latest"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "serverPort",
      "type": "promptString",
      "description": "Local server port",
      "default": "8010"
    },
    {
      "id": "releaseTag",
      "type": "promptString",
      "description": "Release tag to create, for example v1.0.0",
      "default": "v1.0.0"
    }
  ]
}
